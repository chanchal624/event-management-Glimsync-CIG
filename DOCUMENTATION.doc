<div class="container">

    <!-- Title Page -->
    <div class="title-page">
        <h1>GlimSync 📸</h1>
        <div class="subtitle">AI-Powered Event Media Management & Auto-Tagging Platform</div>
        <p><strong>Complete Project Documentation & Implemented Deliverables</strong></p>
